{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    // Bundler: workspace packages (e.g. @repo/business-type-engine) ship TS source; matches Next transpilation without .js rewrites.
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true
  },
  "include": ["src"]
}
