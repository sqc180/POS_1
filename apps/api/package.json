{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@repo/business-type-engine": "workspace:*",
    "@repo/config": "workspace:*",
    "@repo/payments": "workspace:*",
    "@repo/pdf": "workspace:*",
    "@repo/permissions": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "qrcode": "^1.5.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/qrcode": "^1.5.5",
    "mongodb-memory-server": "^11.0.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.3"
  }
}
