{
  "name": "pos-erp-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm exec turbo run build",
    "build:api": "pnpm exec turbo run build --filter=@repo/api",
    "build:web": "pnpm exec turbo run build --filter=@repo/web",
    "dev": "pnpm exec turbo run dev",
    "lint": "pnpm exec turbo run lint",
    "typecheck": "pnpm exec turbo run typecheck",
    "test": "pnpm run test:api",
    "test:api": "pnpm --filter @repo/api test",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
