# API (apps/api)
MONGODB_URI=mongodb://127.0.0.1:27017/pos_erp
JWT_SECRET=change_me_min_16_chars_min_16
PORT=4000
# Comma-separated if Next.js uses another port (e.g. 3001 when 3000 is busy)
WEB_ORIGIN=http://localhost:3000,http://localhost:3001

# Local PDF/file storage root (default: ./storage relative to API process cwd). Not exposed to the web client.
# STORAGE_ROOT=/var/lib/pos-erp/storage

# Razorpay (optional — API server)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Web (apps/web)
# Must match API host:port (see PORT above). Login calls POST {NEXT_PUBLIC_API_URL}/auth/login
NEXT_PUBLIC_API_URL=http://localhost:4000

# API tests (optional CI): from repo root run `pnpm test:api` — uses in-memory MongoDB, not this URI.
