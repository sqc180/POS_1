# Copy to .env and fill in values. Never commit real .env files.

# --- API (apps/api) — server-only; never prefix with NEXT_PUBLIC_
NODE_ENV=development
APP_ENV=local
HOST=0.0.0.0
PORT=4000
# API on your machine (`pnpm dev`): use host loopback (match Docker mongo publish port if you use compose).
MONGODB_URI=mongodb://127.0.0.1:27017/pos_erp_dev
# If something else already uses 27017 on the host, publish compose Mongo on another port, e.g.:
# MONGO_PUBLISH_PORT=27018
# MONGODB_URI=mongodb://127.0.0.1:27018/pos_erp_dev
# API in Docker (`docker compose --profile full`): compose sets mongodb://mongo/... unless you override:
# COMPOSE_MONGODB_URI=mongodb://mongo:27017/pos_erp_dev
MONGODB_CONNECT_RETRIES=5
MONGODB_CONNECT_RETRY_MS=2000
JWT_SECRET=replace_with_at_least_16_random_bytes_hex_or_string

# Public site URL (used for callbacks, links). Optional until you need absolute URLs.
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000

# CORS: comma-separated origins. Prefer CORS_ALLOWED_ORIGINS; WEB_ORIGIN is a legacy alias.
CORS_ALLOWED_ORIGINS=http://localhost:3000
# WEB_ORIGIN=http://localhost:3000

TRUST_PROXY=false
LOG_LEVEL=info
REQUEST_BODY_LIMIT=10485760

STORAGE_PROVIDER=local
STORAGE_ROOT_PATH=./storage
# Legacy alias:
# STORAGE_ROOT=./storage
# Optional subdirectory for PDFs under the storage root:
# PDF_STORAGE_PATH=documents/pdf

# Razorpay (optional in dev)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# --- Web (apps/web) — safe to expose to the browser (NEXT_PUBLIC_* only)
NEXT_PUBLIC_APP_NAME=POS ERP
NEXT_PUBLIC_ENV_NAME=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Legacy alias (same value as NEXT_PUBLIC_API_BASE_URL if both set):
# NEXT_PUBLIC_API_URL=http://localhost:4000
